@{
    ViewData["Title"] = "Attendances";
}

<link rel="stylesheet" href="~/css/Attendance.css" asp-append-version="true" />

<div class="attendance-page">

    <!-- HEADER -->

    <div class="attendance-header">

        <div>
            <h1>Attendances</h1>
            <p>Track and manage daily attendance records</p>
        </div>

        <div class="header-buttons">

            <button class="present-btn"
                    onclick="openAddModal()">

                <i class="fa-solid fa-check"></i>
                Mark Present

            </button>

            <button class="add-btn"
                    onclick="openAddModal()">

                <i class="fa-solid fa-plus"></i>
                Add Record

            </button>

        </div>

    </div>

    <!-- CARDS -->

    <div class="cards">

        <div class="card">

            <div class="icon blue">
                <i class="fa-regular fa-calendar"></i>
            </div>

            <div>
                <p>Total Records</p>
                <h2 id="totalRecords">1</h2>
            </div>

        </div>

        <div class="card">

            <div class="icon green">
                <i class="fa-solid fa-circle-check"></i>
            </div>

            <div>
                <p>Present</p>
                <h2 id="presentCount">1</h2>
            </div>

        </div>

        <div class="card">

            <div class="icon red">
                <i class="fa-solid fa-circle-xmark"></i>
            </div>

            <div>
                <p>Absent</p>
                <h2 id="absentCount">0</h2>
            </div>

        </div>

        <div class="card">

            <div class="icon orange">
                <i class="fa-regular fa-clock"></i>
            </div>

            <div>
                <p>Late</p>
                <h2 id="lateCount">0</h2>
            </div>

        </div>

    </div>

    <!-- TABLE -->

    <div class="attendance-container">

        <div class="table-top">

            <div class="search-box">

                <i class="fa-solid fa-magnifying-glass"></i>

                <input type="text"
                       id="searchInput"
                       placeholder="Search by student name, ID, or subject..."
                       onkeyup="searchAttendance()">

            </div>

        </div>

        <table>

            <thead>

                <tr>

                    <th>STUDENT ID</th>
                    <th>STUDENT NAME</th>
                    <th>COURSE & YEAR</th>
                    <th>SUBJECT CODE</th>
                    <th>DATE</th>
                    <th>TIME IN/OUT</th>
                    <th>STATUS</th>
                    <th>REMARKS</th>
                    <th>ACTIONS</th>

                </tr>

            </thead>

            <tbody id="attendanceTable">

                <tr>

                    <td>101226</td>

                    <td>
                        <strong>Jan Arles</strong>
                    </td>

                    <td>BSME - 1</td>

                    <td>IT 211A</td>

                    <td>Mar 20, 2026</td>

                    <td>
                        In: 8:30 AM <br>
                        Out: 10:30 AM
                    </td>

                    <td>
                        <span class="status present-status">
                            Present
                        </span>
                    </td>

                    <td>Complete attendance</td>

                    <td class="actions">

                        <i class="fa-solid fa-eye view"
                           onclick="viewAttendance(this)"></i>

                        <i class="fa-solid fa-pen-to-square edit"
                           onclick="editAttendance(this)"></i>

                        <i class="fa-solid fa-trash delete"
                           onclick="deleteAttendance(this)"></i>

                    </td>

                </tr>

            </tbody>

        </table>

        <!-- FOOTER -->

        <div class="table-footer">

            <p>
                Total Records:
                <span id="footerTotal">1</span>
            </p>

            <p class="present-text">
                Present:
                <span id="footerPresent">1</span>
            </p>

            <p class="absent-text">
                Absent:
                <span id="footerAbsent">0</span>
            </p>

            <p class="late-text">
                Late:
                <span id="footerLate">0</span>
            </p>

        </div>

    </div>

</div>

<!-- MODAL -->

<div class="modal" id="attendanceModal">

    <div class="modal-content">

        <div class="modal-header">

            <h2 id="modalTitle">Add Attendance</h2>

            <i class="fa-solid fa-xmark"
               onclick="closeModal()"></i>

        </div>

        <div class="form-group">
            <label>Student ID</label>
            <input type="text" id="studentId">
        </div>

        <div class="form-group">
            <label>Student Name</label>
            <input type="text" id="studentName">
        </div>

        <div class="form-group">
            <label>Course & Year</label>
            <input type="text" id="courseYear">
        </div>

        <div class="form-group">
            <label>Subject Code</label>
            <input type="text" id="subjectCode">
        </div>

        <div class="form-group">
            <label>Date</label>
            <input type="date" id="date">
        </div>

        <div class="form-group">
            <label>Time In</label>
            <input type="time" id="timeIn">
        </div>

        <div class="form-group">
            <label>Time Out</label>
            <input type="time" id="timeOut">
        </div>

        <div class="form-group">

            <label>Status</label>

            <select id="status">

                <option>Present</option>
                <option>Absent</option>
                <option>Late</option>

            </select>

        </div>

        <div class="form-group">
            <label>Remarks</label>

            <textarea id="remarks"
                      placeholder="Add any additional notes"></textarea>
        </div>

        <button class="save-btn"
                onclick="saveAttendance()">

            Save Attendance

        </button>

    </div>

</div>

@section Scripts {
    <script src="~/js/Attendance.js"></script>
}