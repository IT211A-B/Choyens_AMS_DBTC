@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <h2>Welcome to Attendance Management</h2>
    <p>Overview of Attendance Management System</p>

    <!-- Cards -->
    <div class="row">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <i class="fas fa-users card-icon"></i>
                    <h5>Total Students</h5>
                    <h3>150</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <i class="fas fa-chalkboard-teacher card-icon"></i>
                    <h5>Total Teachers</h5>
                    <h3>100</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <i class="fas fa-book card-icon"></i>
                    <h5>Active Courses</h5>
                    <h3>4</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <i class="fas fa-clipboard-check card-icon"></i>
                    <h5>Today's Attendance</h5>
                    <h3>90%</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activities -->
    <div class="recent-activities">
        <h4>Recent Activities</h4>
        <div class="activity-item">
            <i class="fas fa-user" style="margin-right: 15px; font-size: 1.2rem;"></i>
            <div style="flex-grow: 1;">
                <div><strong>Jan Artes</strong> Marked <span class="status-present">Present</span></div>
                <div style="font-size: 0.9rem; color: #666;">IT 211A</div>
            </div>
        </div>
        <div class="activity-item">
            <i class="fas fa-user" style="margin-right: 15px; font-size: 1.2rem;"></i>
            <div style="flex-grow: 1;">
                <div><strong>Raphael Pal</strong> Marked <span class="status-present">Present</span></div>
                <div style="font-size: 0.9rem; color: #666;">IT 211A</div>
            </div>
        </div>
        <div class="activity-item">
            <i class="fas fa-user" style="margin-right: 15px; font-size: 1.2rem;"></i>
            <div style="flex-grow: 1;">
                <div><strong>Irish Dela Cruz</strong> Marked <span class="status-absent">Absent</span></div>
                <div style="font-size: 0.9rem; color: #666;">IT 211A</div>
            </div>
        </div>
        <div class="activity-item">
            <i class="fas fa-user" style="margin-right: 15px; font-size: 1.2rem;"></i>
            <div style="flex-grow: 1;">
                <div><strong>Vanneza Domen</strong> Marked <span class="status-present">Present</span></div>
                <div style="font-size: 0.9rem; color: #666;">IT 211A</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(page => {
                page.style.display = 'none';
            });
            document.getElementById(pageId).style.display = 'block';

            document.querySelectorAll('.sidebar a').forEach(link => {
                link.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
        }
    </script>
}