@{
    ViewData["Title"] = "Enrollments";
}

<link rel="stylesheet" href="~/css/Enrollment.css" asp-append-version="true" />
<script src="~/js/Enrollment.js"></script>

<!-- Enrollment Page -->
<div class="enrollment-page">

    <!-- Header section with title and add button -->
    <div class="enrollment-header">

        <div>
            <h1>Enrollments</h1>
            <p>Manage student course enrollments</p>
        </div>

        <button class="add-btn" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i>
            Add Enrollment
        </button>

    </div>

    <!-- Enrollment table and search box -->
    <div class="enrollments-container">

        <div class="search-box">

            <i class="fa-solid fa-magnifying-glass"></i>

            <input type="text"
                   id="searchInput"
                   placeholder="Search by student name, ID, or course code..."
                   onkeyup="searchEnrollment()">

        </div>

        <table>

            <!-- Table headings -->
            <thead>

                <tr>
                    <th>ENROLLMENT ID</th>
                    <th>STUDENT</th>
                    <th>COURSE</th>
                    <th>YEAR/SEMESTER</th>
                    <th>STATUS</th>
                    <th>ACTIONS</th>
                </tr>

            </thead>

            <!-- Enrollment data -->
            <tbody id="enrollmentTable">

                <tr>

                    <td>E001</td>

                    <td>
                        <strong>Jan Arles</strong><br>
                        101226
                    </td>

                    <td>
                        <strong>IT 211A</strong><br>
                        Database Management Systems
                    </td>

                    <td>
                        BSME - 1 - 1st Semester
                    </td>

                    <td>
                        <span class="status enrolled-status">
                            Enrolled
                        </span>
                    </td>

                    <td class="actions">

                        <i class="fa-solid fa-eye view"
                           onclick="viewEnrolment(this)"></i>

                        <i class="fa-solid fa-pen-to-square edit"
                           onclick="editEnrolment(this)"></i>

                        <i class="fa-solid fa-trash delete"
                           onclick="deleteEnrolment(this)"></i>

                    </td>

                </tr>

            </tbody>

        </table>

        <!-- Table footer for enrollment counts -->
        <div class="table-footer">

            <p>
                Total Enrollments:
                <span id="totalEnrollments">1</span>
            </p>

            <p class="enrolled-text">
                Enrolled:
                <span id="enrolledCount">1</span>
            </p>

            <p class="dropped-text">
                Dropped:
                <span id="droppedCount">0</span>
            </p>

            <p class="completed-text">
                Completed:
                <span id="completedCount">0</span>
            </p>

        </div>

    </div>

</div>

<!-- Add/Edit Enrollment Modal -->
<div class="modal" id="enrollmentModal">

    <!-- Modal content -->
    <div class="modal-content">

        <!-- Modal header -->
        <div class="modal-header">

            <h2 id="modalTitle">Add Enrollment</h2>

            <i class="fa-solid fa-xmark"
               onclick="closeModal()"></i>

        </div>

        <!-- Enrollment form fields -->
        <div class="form-group">
            <label>Student ID</label>
            <input type="text" id="studentId">
        </div>

        <div class="form-group">
            <label>Student Name</label>
            <input type="text" id="studentName">
        </div>

        <div class="form-group">
            <label>Course Code</label>
            <input type="text" id="courseCode">
        </div>

        <div class="form-group">
            <label>Course Name</label>
            <input type="text" id="courseName">
        </div>

        <div class="form-group">
            <label>Year Level</label>
            <input type="text" id="yearLevel">
        </div>

        <div class="form-group">
            <label>Semester</label>
            <input type="text" id="semester">
        </div>

        <div class="form-group">
            <label>Status</label>

            <select id="status">

                <option>Enrolled</option>
                <option>Dropped</option>
                <option>Completed</option>

            </select>

        </div>

        <!-- Save enrollment button -->
        <button class="save-btn"
                onclick="saveEnrollment()">

            Save Enrollment

        </button>

    </div>

</div>