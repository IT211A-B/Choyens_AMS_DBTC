@{
    ViewData["Title"] = "Teacher";
}
<link rel="stylesheet" href="~/css/Teacher.css" asp-append-version="true" />
<script src="~/js/Teacher.js" asp-append-version="true"></script>

<div class="teacher-page">
    <div class="teacher-header">
        <div>
            <h1>Teacher</h1>
            <p>Manage teacher informations</p>
        </div>
        <button class="add-btn" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i>
            Add Teacher
        </button>
    </div>
    <div class="teachers-container">

        <div class="search-box">

            <i class="fa-solid fa-magnifying-glass"></i>

            <input type="text"
                   id="searchInput"
                   placeholder="Search by name or Teacher ID..."
                   onkeyup="searchTeacher()">

        </div>

        <table>

            <thead>

                <tr>
                    <th>TEACHER ID</th>
                    <th>TEACHER NAME</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Specialization</th>
                    <th>ACTIONS</th>
                </tr>

            </thead>

            <tbody id="teacherTable">

                <tr>

                    <td>T-01-226</td>
                    <td>Liebert Tabares</td>
                    <td>liebert@gmail.com</td>
                    <td>ME Department</td>
                    <td>Mechanical Shop</td>

                    <td class="actions">

                        <i class="fa-solid fa-eye view"
                           onclick="viewTeacher(this)"></i>

                        <i class="fa-solid fa-pen-to-square edit"                   
                           onclick="editTeacher(this)"></i>

                        <i class="fa-solid fa-trash delete"
                           onclick="deleteTeacher(this)"></i>

                    </td>

                </tr>

                <tr>

                    <td>T-01-226</td>
                    <td>Liebert Tabares</td>
                    <td>liebert@gmail.com</td>
                    <td>ME Department</td>
                    <td>Mechanical Shop</td>

                    <td class="actions">

                        <i class="fa-solid fa-eye view"
                           onclick="viewTeacher(this)"></i>

                        <i class="fa-solid fa-pen-to-square edit"
                           onclick="editTeacher(this)"></i>

                        <i class="fa-solid fa-trash delete"
                           onclick="deleteTeacher(this)"></i>

                    </td>

                </tr>

                <tr>

                    <td>T-01-226</td>
                    <td>Liebert Tabares</td>
                    <td>liebert@gmail.com</td>
                    <td>ME Department</td>
                    <td>Mechanical Shop</td>

                    <td class="actions">

                        <i class="fa-solid fa-eye view"
                           onclick="viewTeacher(this)"></i>

                        <i class="fa-solid fa-pen-to-square edit"
                           onclick="editTeacher(this)"></i>

                        <i class="fa-solid fa-trash delete"
                           onclick="deleteTeacher(this)"></i>

                    </td>

                </tr> 

            <tr>

                <td>T-01-226</td>
                <td>Liebert Tabares</td>
                <td>liebert@gmail.com</td>
                <td>ME Department</td>
                <td>Mechanical Shop</td>

                <td class="actions">

                    <i class="fa-solid fa-eye view"
                       onclick="viewTeacher(this)"></i>

                    <i class="fa-solid fa-pen-to-square edit"
                       onclick="editTeacher(this)"></i>

                    <i class="fa-solid fa-trash delete"
                       onclick="deleteTeacher(this)"></i>

                </td>

            </tr>

            </tbody>

        </table>

        <div class="table-footer">

            <p>
                Total Teachers:
                <span id="totalTeachers">4</span>
            </p>

        </div>

    </div>

</div>

<div class="modal" id="teacherModal">

    <div class="modal-content">

        <div class="modal-header">
            <h2 id="modalTitle">Add Teacher</h2>
            <i class="fa-solid fa-xmark" onclick="closeModal()"></i>
        </div>

        <div class="form-group">
            <label>Teacher ID</label>
            <input type="text" id="teacherId">
        </div>

        <div class="form-group">
            <label>Teacher Name</label>
            <input type="text" id="teacherName">
        </div>

        <div class="form-group">
            <label>Email</label>
            <input type="text" id="teacherEmail">
        </div>

        <div class="form-group">
            <label>Department</label>
            <input type="text" id="teacherDepartment">
        </div>

        <div class="form-group">
            <label>Specialization</label>
            <input type="text" id="specialization">
        </div>
            
        <div class="form-group">
            <label>Specialization Date</label>
            <input type="date" id="specializationDate">
        </div>

        <button class="save-btn" onclick="saveTeacher()">
            Save Teacher
        </button>

    </div>

</div>