<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AMS_DBTC_Frontend</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AMS_DBTC_Frontend.styles.css" asp-append-version="true" />

    <style>
        body {
            margin: 0;
            padding: 0;
        }

        .main-layout {
            display: flex;
            min-height: calc(100vh - 70px);
        }

        .sidebar {
            width: 250px;
            background-color: #0F2A44;
            padding: 20px;
        }

        .sidebar h4 {
            color: white;
            margin-bottom: 20px;
        }

        .sidebar a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 10px;
            transition: 0.3s;
        }

        .sidebar a:hover {
            background-color: #1c466d;
        }

        .content-area {
            flex: 1;
            padding: 20px;
            background-color: #f5f5f5;
        }

        footer {
            position: relative;
            bottom: 0;
            width: 100%;
        }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">

                <a class="navbar-brand"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    AMS_DBTC_Frontend
                </a>

            </div>
        </nav>
    </header>

    <div class="main-layout">

        <div class="sidebar">

            <h4>Navigation</h4>

            <a asp-controller="Home"
               asp-action="Index">
                Dashboard
            </a>

            <a asp-controller="Home"
               asp-action="Privacy">
                Student
            </a>

            <a asp-controller="Home"
               asp-action="Teacher">
                Teacher
            </a>

            <a asp-controller="Home"
               asp-action="Course">
                Course
            </a>

            <a asp-controller="Home"
               asp-action="Enrolment">
                Enrolment
            </a>

            <a asp-controller="Home"
               asp-action="Attendance">
                Attendance
            </a>

        </div>

        <div class="content-area">
            <main role="main">
                @RenderBody()
            </main>
        </div>

    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AMS_DBTC_Frontend
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>