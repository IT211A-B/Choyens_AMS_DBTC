<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - AMS_DBTC_Frontend</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/_Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AMS_DBTC_Frontend.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
</head>

<body>

    <header class="topbar">

        <div class="logo">
            AMS_DBTC_Frontend
        </div>

    </header>


    <div class="main-layout">

        <aside class="sidebar">

            <h4>Navigation</h4>

            <a asp-controller="Home" asp-action="Index">
                Dashboard
            </a>

            <a asp-controller="Home" asp-action="Privacy">
                Student
            </a>

            <a asp-controller="Home" asp-action="Teacher">
                Teacher
            </a>

            <a asp-controller="Home" asp-action="Course">
                Course
            </a>

            <a asp-controller="Home" asp-action="Enrolment">
                Enrolment
            </a>

            <a asp-controller="Home" asp-action="Attendance">
                Attendance
            </a>

        </aside>


        <main class="content-area">

            @RenderBody()

        </main>

    </div>


    <footer class="footer">

        <p>&copy; 2026 - AMS_DBTC_Frontend</p>

    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>