@model IEnumerable<AMS_Choyenss_Domen_FE_.Models.StudentViewModel>

@{
    ViewData["Title"] = "Student List";
}

<h1>Student Management</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Course</td>
            </tr>
        }
    </tbody>
</table>
